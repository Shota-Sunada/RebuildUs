{
  "version": "2.0.0",
  "type": "shell",
  "options": {
    "shell": {
      "executable": "powershell.exe"
    }
  },
  "presentation": {
    "echo": false,
    "reveal": "always",
    "focus": true,
    "panel": "shared",
    "showReuseMessage": true,
    "clear": true
  },
  "problemMatcher": [],
  "tasks": [
    {
      "label": "Build Impostor Debug",
      "command": "dotnet build RebuildUs.Impostor/RebuildUs.Impostor.csproj -c Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Impostor Release",
      "command": "dotnet build RebuildUs.Impostor/RebuildUs.Impostor.csproj -c Release",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Launcher",
      "command": "dotnet cake build.cake --target=BuildLauncher",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Debug",
      "command": "dotnet cake build.cake --target=BuildDebug",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Relase",
      "command": "dotnet cake build.cake --target=BuildRelease",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Sync Translations",
      "command": "go run Tools/TranslateSync/translate_sync.go",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Add Translations",
      "command": "go run Tools/AddTranslation/add_translation.go",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Taskkill",
      "command": "dotnet cake build.cake --target=Taskkill",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "BepInEx Updater Publish",
      "command": "dotnet cake build.cake --target=PublishUpdater",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Generate Release Zip",
      "command": "dotnet cake build.cake --target=GenerateRelease --modVersion=${input:releaseVersion}",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start Debug",
      "command": "dotnet cake build.cake --target=StartDebug",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Boot AmongUs",
      "command": "dotnet cake build.cake --target=StartDebugBoot",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Format",
      "command": "dotnet cake build.cake --target=FormatCode",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Format Translation Json",
      "command": "dotnet cake build.cake --target=FormatTranslations",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Reactor Debug",
      "command": "dotnet cake build.cake --target=BuildReactor",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Reactor Release",
      "command": "dotnet cake build.cake --target=BuildReactor",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Submerged Debug",
      "command": "dotnet cake build.cake --target=BuildSubmerged --configuration=Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Submerged Release",
      "command": "dotnet cake build.cake --target=BuildSubmerged --configuration=Release",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "releaseVersion",
      "type": "promptString",
      "description": "Enter the version for the release (e.g., 1.2.3):",
      "default": "1.0.0"
    }
  ]
}